# ─── Supabase (Database) ───────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Anthropic (AI) ────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── WhatsApp Business API ─────────────────────────
# Get from: https://developers.facebook.com → your app → WhatsApp
WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=sokoni_nigeria_2025   # You pick this — any random string

# ─── App Config ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://sokoni.africa
NEXT_PUBLIC_APP_NAME=Sokoni Africa
